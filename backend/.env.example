# نموذج متغيّرات البيئة لمنصة تكافل وأثر (backend)
# انسخه إلى backend/.env واضبط القيم. لا تُودِع .env في git.

# الأمان — إلزامي في الإنتاج
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# قاعدة البيانات (افتراضياً SQLite محلياً؛ في الإنتاج استخدم PostgreSQL)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS / CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=

# حساب المشرف الافتراضي (يُنشأ عبر create_admin) — غيّر كلمة المرور بعد أول دخول
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@takaful.com
ADMIN_PASSWORD=change-me
